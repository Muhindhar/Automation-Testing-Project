<?xml version="1.0" encoding="UTF-8"?>
<extentreports>
	<configuration>
		<!-- report theme -->
		<theme>dark</theme>
		<!-- document encoding -->
		<encoding>UTF-8</encoding>
		<!-- protocol for script and stylesheets -->
		<protocol>https</protocol>
		<!-- title of the document -->
		<documentTitle>Smart Hospital - Automation Report</documentTitle>
		<!-- report name - displayed at top-nav -->
		<reportName>Smart Hospital Test Automation Report</reportName>
		<!-- view report without internet -->
		<offlineMode>true</offlineMode>
		<!-- settings to change component location -->
		<testViewChartLocation>top</testViewChartLocation>
		<!-- enable timeline -->
		<timelineEnabled>true</timelineEnabled>
		<!-- chart visibility on dashboard -->
		<chartVisibleOnDashboard>true</chartVisibleOnDashboard>
	</configuration>
</extentreports>
